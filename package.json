{
  "name": "pos-run",
  "private": true,
  "version": "1.0.7",
  "description": "POS Run — restaurant point of sale (Electron + Express + Supabase)",
  "author": "Safgate",
  "repository": {
    "type": "git",
    "url": "https://github.com/Safgate/pos-run.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:server:build": "esbuild server.ts --bundle --platform=node --outfile=dist/server-dev.cjs --external:vite --external:fsevents --external:@vitejs/plugin-react --external:@tailwindcss/vite",
    "dev:server:watch": "esbuild server.ts --bundle --platform=node --outfile=dist/server-dev.cjs --external:vite --external:fsevents --external:@vitejs/plugin-react --external:@tailwindcss/vite --watch",
    "dev": "npm run dev:server:build && concurrently \"npm run dev:server:watch\" \"node --watch dist/server-dev.cjs\"",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs --external:vite --external:fsevents --external:@vitejs/plugin-react --external:@tailwindcss/vite",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "start": "npm run build:server && NODE_ENV=production node dist/server.cjs",
    "electron:dev": "npm run dev:server:build && concurrently \"npm run dev:server:watch\" \"node --watch dist/server-dev.cjs\" \"wait-on http://127.0.0.1:3001 && electron --no-sandbox electron-main.cjs\"",
    "electron:build": "npm run build && npm run build:server && electron-builder --publish never",
    "build:windows": "npm run build && npm run build:server && electron-builder --win --publish never",
    "build:windows:portable": "npm run build && npm run build:server && electron-builder --win --x64 -c.win.target=portable --publish never",
    "build:windows:dir": "npm run build && npm run build:server && electron-builder --win --dir --publish never",
    "build:windows:nsis": "npm run build && npm run build:server && electron-builder --win --x64 -c.win.target=nsis --publish never",
    "build:windows:cross": "bash scripts/build-windows-cross.sh"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.posrun.app",
    "productName": "POS Run",
    "asarUnpack": [
      "dist/server.cjs"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4",
    "ws": "^8.19.0"
  }
}
