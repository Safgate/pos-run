{
  "name": "react-example",
  "private": true,
  "version": "1.0.2",
  "description": "Bilbao POS — restaurant point of sale (Electron + Express + Supabase)",
  "author": "Safgate",
  "repository": {
    "type": "git",
    "url": "https://github.com/Safgate/BILBAO.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --outfile=dist/server.cjs --external:vite --external:fsevents",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "electron:dev": "concurrently \"tsx server.ts\" \"wait-on http://127.0.0.1:3000 && electron --no-sandbox electron-main.cjs\"",
    "electron:build": "npm run build && npm run build:server && electron-builder --publish never",
    "build:windows": "npm run build && npm run build:server && electron-builder --win --publish never",
    "build:windows:portable": "npm run build && npm run build:server && electron-builder --win --x64 -c.win.target=portable --publish never",
    "build:windows:dir": "npm run build && npm run build:server && electron-builder --win --dir --publish never",
    "build:windows:nsis": "npm run build && npm run build:server && electron-builder --win --x64 -c.win.target=nsis --publish never"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.bilbao.pos",
    "productName": "Bilbao POS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4",
    "ws": "^8.19.0"
  }
}
