# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public bucket for menu item photos (create in Supabase → Storage → New bucket → name e.g. menu-images → Public)
# Optional override if you use a different bucket name:
# SUPABASE_STORAGE_BUCKET=menu-images

# Electron: silent receipt printing — exact printer name as shown in OS (optional; uses default printer if empty)
# RECEIPT_PRINTER_NAME=EPSON TM-T20III Receipt
# Print scale (10–200), default 100 = 100% size (no shrink-to-fit)
# RECEIPT_PRINT_SCALE=100
