# HTTP port for the embedded Express server (default 3001). Optional override:
# PORT=3001

# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# After pulling new features, run any new SQL in /sql/ against your project (e.g. sql/shift_expenses.sql for shift expenses).

# Public bucket for menu item photos (create in Supabase → Storage → New bucket → name e.g. menu-images → Public)
# Optional override if you use a different bucket name:
# SUPABASE_STORAGE_BUCKET=menu-images

# Electron: silent receipt printing — exact printer name as shown in OS (optional; uses default printer if empty)
# RECEIPT_PRINTER_NAME=EPSON TM-T20III Receipt
# Print scale (10–200), default 33% (about 3x smaller)
# RECEIPT_PRINT_SCALE=33
#
# Linux CUPS (optional): set defaults on the thermal queue once so HTML receipts get correct roll width + cut:
# lpoptions -p GA_E200 -o media=X80MMY2000MM -o CutType=1
#
# Chromium often ignores CutType for silent print — enable a raw ESC/POS cut after each receipt (same queue must accept raw):
# RECEIPT_POST_CUT_ESC_POS=1
# Optional: hex bytes if your printer needs a different cut command (default full cut 1D5600):
# RECEIPT_ESC_POS_CUT_HEX=1D5600

# POS receipt base width in mm (58–120). Default 80 (standard 80mm rolls).
# VITE_RECEIPT_PAPER_MM=80
# Multiply layout width (default 1 = base width).
# VITE_RECEIPT_WIDTH_MULTIPLIER=1
